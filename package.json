{
  "name": "@joltdesign/db-find-replace",
  "packageManager": "yarn@4.14.0+sha512.31053dd4c730c75e8665ad00bbfe07a7bed08aef54c5edfd8d484463680180b1c87035a61b9e15ff2cad310a329176cac433009e2d402ac69d1386f9445d7ccb",
  "private": true,
  "devDependencies": {
    "@joltdesign/scripts": "^1.5.0",
    "npm-run-all2": "^8.0.4"
  },
  "scripts": {
    "cli": "jolt cmd -q '{cmd:compose}' exec interface php srdb.cli.php -h '{db:host}' -u '{db:user}' -p'{db:pass}' -n '{db:db}'",
    "test": "run-s test:up test:await test:run test:down",
    "test:up": "jolt cmd -q '{cmd:compose}' --profile=test up -d test_db interface",
    "test:await": "jolt db await test_db",
    "test:down": "jolt cmd -q '{cmd:compose}' --profile=test down test_db",
    "test:run": "jolt cmd -q '{cmd:compose}' exec interface php ./vendor/bin/phpunit",
    "export": "jolt cmd -q '{cmd:compose}' exec '{db:host}' '{db:dumpCmd}' -h '{db:host}' -u '{db:user}' -p'{db:pass}' -n '{db:db}' > ./db-output/output.sql"
  }
}
